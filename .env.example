# Required: Anthropic provider key — populate from your existing key store
ANTHROPIC_API_KEY=

# Optional: override the model used by the LLM client
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: maximum estimated USD cost per Python process invocation
# Default: 1.00 if unset. Hard-stops the LLM client when accumulated estimated cost exceeds this.
# ATLAS_LLM_MAX_USD=1.00

# Optional: maximum estimated USD cost accumulated across ALL pipeline.py invocations in a calendar day
# Default: 3.00 if unset. Enforced via .atlas-spend.json (cross-process, file-locked).
# Resets at midnight UTC. Raise this when running large intentional audit batches.
# ATLAS_LLM_DAILY_MAX_USD=3.00

# Optional: shared cross-caller global daily cap in the centralized ledger.
# Default: 5.00 if unset.
# ATLAS_LLM_GLOBAL_DAILY_MAX_USD=5.00

# Optional: caller ID in shared spend ledger. Default: atlas-plan-check
# ATLAS_LLM_CALLER_ID=atlas-plan-check

# Optional: max successful LLM calls per process run for this caller. Default: 0 (disabled)
# ATLAS_LLM_MAX_CALLS_PER_RUN=0

# Optional: centralized shared ledger path used by services and atlas-store.
# ATLAS_LLM_SPEND_STATE_FILE=/opt/stack/services/automations/state/llm_cost_gate.json

# Optional: disable or shadow the shared cost gate if needed for troubleshooting.
# ATLAS_LLM_COST_GATE_ENABLED=true
# ATLAS_LLM_COST_GATE_ENFORCE=true
